parameters:
    level: max

    paths:
        - src
        - tests

    excludePaths:
        - tests/Application/*

    bootstrapFiles:
        - vendor/autoload.php

    # Symfony Configuration
    symfony:
        consoleApplicationLoader: tests/PHPStan/console_application.php

    # Doctrine Configuration
    doctrine:
        repositoryClass: Doctrine\ORM\EntityRepository
        objectManagerLoader: tests/PHPStan/object_manager.php
        # entities use nullable properties for non-null columns (set before persist), the standard
        # Sylius pattern
        allowNullablePropertyForRequiredField: true

    reportUnmatchedIgnoredErrors: false
    treatPhpDocTypesAsCertain: false

    ignoreErrors:
        # phpstan-doctrine resolves interface-typed associations (e.g. ChannelInterface) to their
        # concrete class through Doctrine's resolve_target_entities, then rejects the broader
        # interface as the property type. This is a false positive for Sylius's interface-based
        # model overrides — the whole point of typing associations against interfaces — so we ignore
        # it. The mappings themselves are validated against the database by `doctrine:schema:validate`
        # in CI.
        -
            identifier: doctrine.associationType
            message: '#type mapping mismatch: property can contain .+ but database expects#'
