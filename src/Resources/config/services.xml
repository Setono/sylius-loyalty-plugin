<?xml version="1.0" encoding="UTF-8" ?>
<container xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://symfony.com/schema/dic/services"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <service id="Setono\SyliusLoyaltyPlugin\Provider\LoyaltyProgramProvider">
            <argument type="service" id="setono_sylius_loyalty.factory.program" />
            <argument type="service" id="setono_sylius_loyalty.repository.program" />
            <argument type="service" id="doctrine" />
        </service>
        <service id="Setono\SyliusLoyaltyPlugin\Provider\LoyaltyProgramProviderInterface"
                 alias="Setono\SyliusLoyaltyPlugin\Provider\LoyaltyProgramProvider" />

        <service id="Setono\SyliusLoyaltyPlugin\Provider\LoyaltyAccountProvider">
            <argument type="service" id="setono_sylius_loyalty.factory.account" />
            <argument type="service" id="setono_sylius_loyalty.repository.account" />
            <argument type="service" id="doctrine" />
        </service>
        <service id="Setono\SyliusLoyaltyPlugin\Provider\LoyaltyAccountProviderInterface"
                 alias="Setono\SyliusLoyaltyPlugin\Provider\LoyaltyAccountProvider" />

        <service id="Setono\SyliusLoyaltyPlugin\Doctrine\ORM\Listener\LoyaltyTransactionDiscriminatorMapListener">
            <argument>%sylius.resources%</argument>
            <tag name="doctrine.event_listener" event="loadClassMetadata" />
        </service>

        <service id="Setono\SyliusLoyaltyPlugin\Replay\LotReplayer" />

        <service id="Setono\SyliusLoyaltyPlugin\Command\ExpirePointsCommand">
            <argument type="service" id="setono_sylius_loyalty.repository.account" />
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Ledger\LoyaltyLedgerInterface" />
            <tag name="console.command" />
        </service>

        <service id="Setono\SyliusLoyaltyPlugin\Ledger\LoyaltyLedger">
            <argument type="service" id="doctrine" />
            <argument type="service" id="event_dispatcher" />
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Replay\LotReplayer" />
            <call method="setLogger">
                <argument type="service" id="logger" on-invalid="ignore" />
            </call>
        </service>
        <service id="Setono\SyliusLoyaltyPlugin\Ledger\LoyaltyLedgerInterface"
                 alias="Setono\SyliusLoyaltyPlugin\Ledger\LoyaltyLedger" />

        <!-- Earning rule engine: conditions -->
        <service id="Setono\SyliusLoyaltyPlugin\Rule\Condition\OrderTotalAtLeastCondition">
            <tag name="setono_sylius_loyalty.earning_condition" />
        </service>
        <service id="Setono\SyliusLoyaltyPlugin\Rule\Condition\DateWindowCondition">
            <tag name="setono_sylius_loyalty.earning_condition" />
        </service>
        <service id="Setono\SyliusLoyaltyPlugin\Rule\Condition\DayOfWeekCondition">
            <tag name="setono_sylius_loyalty.earning_condition" />
        </service>

        <service id="Setono\SyliusLoyaltyPlugin\Rule\EarningConditionEvaluator">
            <argument type="tagged_locator" tag="setono_sylius_loyalty.earning_condition" default-index-method="getType" />
        </service>
        <service id="Setono\SyliusLoyaltyPlugin\Rule\EarningConditionEvaluatorInterface"
                 alias="Setono\SyliusLoyaltyPlugin\Rule\EarningConditionEvaluator" />

        <!-- Earning rule engine: base amounts -->
        <service id="Setono\SyliusLoyaltyPlugin\Rule\Amount\FixedAmount">
            <tag name="setono_sylius_loyalty.earning_amount" />
        </service>
        <service id="Setono\SyliusLoyaltyPlugin\Rule\Amount\PerAmount">
            <tag name="setono_sylius_loyalty.earning_amount" />
        </service>

        <service id="Setono\SyliusLoyaltyPlugin\Rule\EarningAmountEvaluator">
            <argument type="tagged_locator" tag="setono_sylius_loyalty.earning_amount" default-index-method="getType" />
        </service>
        <service id="Setono\SyliusLoyaltyPlugin\Rule\EarningAmountEvaluatorInterface"
                 alias="Setono\SyliusLoyaltyPlugin\Rule\EarningAmountEvaluator" />

        <!-- Earning rule engine: basis + calculator -->
        <service id="Setono\SyliusLoyaltyPlugin\Rule\Basis\EarningBasisProvider" />
        <service id="Setono\SyliusLoyaltyPlugin\Rule\Basis\EarningBasisProviderInterface"
                 alias="Setono\SyliusLoyaltyPlugin\Rule\Basis\EarningBasisProvider" />

        <service id="Setono\SyliusLoyaltyPlugin\Rule\EarningCalculator">
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Rule\Basis\EarningBasisProviderInterface" />
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Rule\EarningConditionEvaluatorInterface" />
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Rule\EarningAmountEvaluatorInterface" />
        </service>
        <service id="Setono\SyliusLoyaltyPlugin\Rule\EarningCalculatorInterface"
                 alias="Setono\SyliusLoyaltyPlugin\Rule\EarningCalculator" />

        <!-- Order earning pipeline -->
        <service id="Setono\SyliusLoyaltyPlugin\Earning\OrderPointsAwarder">
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Provider\LoyaltyAccountProviderInterface" />
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Provider\LoyaltyProgramProviderInterface" />
            <argument type="service" id="setono_sylius_loyalty.repository.earning_rule" />
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Rule\EarningCalculatorInterface" />
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Rule\Basis\EarningBasisProviderInterface" />
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Ledger\LoyaltyLedgerInterface" />
        </service>
        <service id="Setono\SyliusLoyaltyPlugin\Earning\OrderPointsAwarderInterface"
                 alias="Setono\SyliusLoyaltyPlugin\Earning\OrderPointsAwarder" />

        <!-- Action earning pipeline: evaluates the channel's rules for an action trigger (no order) -->
        <service id="Setono\SyliusLoyaltyPlugin\Earning\ActionPointsAwarder">
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Provider\LoyaltyAccountProviderInterface" />
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Provider\LoyaltyProgramProviderInterface" />
            <argument type="service" id="setono_sylius_loyalty.repository.earning_rule" />
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Rule\EarningConditionEvaluatorInterface" />
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Rule\EarningAmountEvaluatorInterface" />
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Ledger\LoyaltyLedgerInterface" />
        </service>
        <service id="Setono\SyliusLoyaltyPlugin\Earning\ActionPointsAwarderInterface"
                 alias="Setono\SyliusLoyaltyPlugin\Earning\ActionPointsAwarder" />

        <!-- Action trigger: awards the customer_registered rules (signup bonus) on registration -->
        <service id="Setono\SyliusLoyaltyPlugin\EventSubscriber\CustomerRegistrationSubscriber">
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Earning\ActionPointsAwarderInterface" />
            <argument type="service" id="sylius.context.channel" />
            <tag name="kernel.event_subscriber" />
        </service>

        <!-- Resolves which channels a context-less action trigger awards on. A composite of every tagged
             resolver, de-duplicated by channel code; a project can tag its own. -->
        <service id="Setono\SyliusLoyaltyPlugin\Earning\CompositeTriggerChannelResolver" />
        <service id="Setono\SyliusLoyaltyPlugin\Earning\TriggerChannelResolverInterface"
                 alias="Setono\SyliusLoyaltyPlugin\Earning\CompositeTriggerChannelResolver" />

        <service id="Setono\SyliusLoyaltyPlugin\Earning\LoyaltyAccountChannelResolver">
            <argument type="service" id="setono_sylius_loyalty.repository.account" />
            <tag name="setono_sylius_loyalty.trigger_channel_resolver" priority="30" />
        </service>
        <service id="Setono\SyliusLoyaltyPlugin\Earning\LastOrderChannelResolver">
            <argument type="service" id="sylius.repository.order" />
            <tag name="setono_sylius_loyalty.trigger_channel_resolver" priority="20" />
        </service>
        <service id="Setono\SyliusLoyaltyPlugin\Earning\SingleChannelResolver">
            <argument type="service" id="sylius.repository.channel" />
            <tag name="setono_sylius_loyalty.trigger_channel_resolver" priority="10" />
        </service>

        <!-- Action trigger: awards the product_review_approved rules when a review is accepted (both
             adapters; workflow tag here, winzou callback via the extension's prepend) -->
        <service id="Setono\SyliusLoyaltyPlugin\Earning\Trigger\ReviewApprovedStateMachineListener" public="true">
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Earning\ActionPointsAwarderInterface" />
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Earning\TriggerChannelResolverInterface" />
            <tag name="kernel.event_listener" event="workflow.sylius_product_review.completed.accept" method="onWorkflowReviewAccepted" />
        </service>

        <!-- Action trigger: awards the customer_birthday rules to today's birthday customers (a daily cron) -->
        <service id="Setono\SyliusLoyaltyPlugin\Provider\BirthdayCustomerProvider">
            <argument type="service" id="doctrine" />
            <argument>%sylius.model.customer.class%</argument>
        </service>
        <service id="Setono\SyliusLoyaltyPlugin\Provider\BirthdayCustomerProviderInterface"
                 alias="Setono\SyliusLoyaltyPlugin\Provider\BirthdayCustomerProvider" />

        <service id="Setono\SyliusLoyaltyPlugin\Command\AwardBirthdayPointsCommand">
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Provider\BirthdayCustomerProviderInterface" />
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Earning\TriggerChannelResolverInterface" />
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Earning\ActionPointsAwarderInterface" />
            <tag name="console.command" />
        </service>

        <service id="Setono\SyliusLoyaltyPlugin\Message\Handler\AwardOrderPointsHandler">
            <argument type="service" id="sylius.repository.order" />
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Earning\OrderPointsAwarderInterface" />
            <tag name="messenger.message_handler" bus="setono_sylius_loyalty.command_bus" />
        </service>

        <!-- Award trigger: hooks both state-machine adapters (workflow tags here; winzou callbacks are
             registered by the extension's prepend). Each only fires under the app's active adapter. -->
        <service id="Setono\SyliusLoyaltyPlugin\Earning\Trigger\AwardOrderPointsTrigger">
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Provider\LoyaltyProgramProviderInterface" />
            <argument type="service" id="setono_sylius_loyalty.command_bus" />
        </service>
        <service id="Setono\SyliusLoyaltyPlugin\Earning\Trigger\AwardOrderPointsTriggerInterface"
                 alias="Setono\SyliusLoyaltyPlugin\Earning\Trigger\AwardOrderPointsTrigger" />

        <service id="Setono\SyliusLoyaltyPlugin\Earning\Trigger\AwardOrderPointsStateMachineListener" public="true">
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Earning\Trigger\AwardOrderPointsTriggerInterface" />
            <tag name="kernel.event_listener" event="workflow.sylius_order_payment.completed.pay" method="onWorkflowPaymentPaid" />
            <tag name="kernel.event_listener" event="workflow.sylius_order.completed.fulfill" method="onWorkflowOrderFulfilled" />
        </service>

        <!-- Clawback trigger: reverses earned points on cancellation / refund. Same both-adapters wiring
             as the award trigger (workflow tags here, winzou callbacks in the extension prepend). -->
        <service id="Setono\SyliusLoyaltyPlugin\Message\Handler\ClawbackOrderPointsHandler">
            <argument type="service" id="sylius.repository.order" />
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Provider\LoyaltyProgramProviderInterface" />
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Ledger\LoyaltyLedgerInterface" />
            <tag name="messenger.message_handler" bus="setono_sylius_loyalty.command_bus" />
        </service>

        <service id="Setono\SyliusLoyaltyPlugin\Earning\Trigger\ClawbackOrderPointsStateMachineListener" public="true">
            <argument type="service" id="setono_sylius_loyalty.command_bus" />
            <tag name="kernel.event_listener" event="workflow.sylius_order.completed.cancel" method="onWorkflowOrderCancelled" />
            <tag name="kernel.event_listener" event="workflow.sylius_order_payment.completed.refund" method="onWorkflowPaymentRefunded" />
        </service>

        <!-- Redemption: turns the requested points into an order adjustment. Priority 15 runs after
             promotions (20) and before tax (10). -->
        <service id="Setono\SyliusLoyaltyPlugin\Redemption\RedemptionCalculator" />
        <service id="Setono\SyliusLoyaltyPlugin\Redemption\RedemptionCalculatorInterface"
                 alias="Setono\SyliusLoyaltyPlugin\Redemption\RedemptionCalculator" />

        <service id="Setono\SyliusLoyaltyPlugin\Redemption\RedemptionOrderProcessor">
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Provider\LoyaltyAccountProviderInterface" />
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Provider\LoyaltyProgramProviderInterface" />
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Redemption\RedemptionCalculatorInterface" />
            <argument type="service" id="sylius.factory.adjustment" />
            <tag name="sylius.order_processor" priority="15" />
        </service>

        <!-- Redemption trigger: debits the redeemed points synchronously when checkout completes and
             returns them on cancellation. Both adapters (workflow tags here, winzou in the prepend). -->
        <service id="Setono\SyliusLoyaltyPlugin\Redemption\OrderRedeemer">
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Provider\LoyaltyAccountProviderInterface" />
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Ledger\LoyaltyLedgerInterface" />
        </service>
        <service id="Setono\SyliusLoyaltyPlugin\Redemption\OrderRedeemerInterface"
                 alias="Setono\SyliusLoyaltyPlugin\Redemption\OrderRedeemer" />

        <service id="Setono\SyliusLoyaltyPlugin\Redemption\RedemptionStateMachineListener" public="true">
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Redemption\OrderRedeemerInterface" />
            <tag name="kernel.event_listener" event="workflow.sylius_order_checkout.completed.complete" method="onWorkflowCheckoutCompleted" />
            <tag name="kernel.event_listener" event="workflow.sylius_order.completed.cancel" method="onWorkflowOrderCancelled" />
        </service>

        <service id="Setono\SyliusLoyaltyPlugin\Validator\Constraint\RedemptionIsValidValidator">
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Provider\LoyaltyAccountProviderInterface" />
            <tag name="validator.constraint_validator" />
        </service>

        <!-- Shop redemption widget: adds the "spend points" field to the cart form (submitted with the cart-save flow) -->
        <service id="Setono\SyliusLoyaltyPlugin\Form\Extension\CartTypeExtension">
            <tag name="form.type_extension" />
        </service>

        <!-- Shop "My loyalty" account page: balance hero + ledger history. The transaction repository
             is the Sylius resource repository (setono_sylius_loyalty.repository.transaction). -->
        <service id="Setono\SyliusLoyaltyPlugin\Repository\LoyaltyTransactionRepositoryInterface"
                 alias="setono_sylius_loyalty.repository.transaction" />

        <service id="Setono\SyliusLoyaltyPlugin\Controller\Shop\ShowLoyaltyAccountAction" public="true">
            <argument type="service" id="sylius.context.shopper" />
            <argument type="service" id="setono_sylius_loyalty.repository.account" />
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Repository\LoyaltyTransactionRepositoryInterface" />
            <argument type="service" id="twig" />
        </service>

        <!-- Adds the "My loyalty" item to the shop account menu -->
        <service id="Setono\SyliusLoyaltyPlugin\EventSubscriber\AccountMenuSubscriber">
            <tag name="kernel.event_subscriber" />
        </service>

        <!-- Admin: the read-only accounts grid (reached from the loyalty dashboard) -->
        <service id="Setono\SyliusLoyaltyPlugin\Grid\LoyaltyAccountGrid">
            <argument>%setono_sylius_loyalty.model.account.class%</argument>
            <argument>%sylius.model.channel.class%</argument>
            <tag name="sylius.grid" />
        </service>

        <!-- Admin loyalty dashboard: Phase 1 stats + the single "Loyalty" Marketing menu entry -->
        <service id="Setono\SyliusLoyaltyPlugin\EventSubscriber\AdminMenuSubscriber">
            <tag name="kernel.event_subscriber" />
        </service>

        <service id="Setono\SyliusLoyaltyPlugin\Controller\Admin\DashboardAction" public="true">
            <argument type="service" id="setono_sylius_loyalty.repository.account" />
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Repository\LoyaltyTransactionRepositoryInterface" />
            <argument type="service" id="twig" />
        </service>

        <!-- Admin ledger inspector: account summary + FIFO lot state + invariant check + full ledger -->
        <service id="Setono\SyliusLoyaltyPlugin\Controller\Admin\ShowLoyaltyAccountAction" public="true">
            <argument type="service" id="setono_sylius_loyalty.repository.account" />
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Repository\LoyaltyTransactionRepositoryInterface" />
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Replay\LotReplayer" />
            <argument type="service" id="twig" />
        </service>
    </services>
</container>
