<?xml version="1.0" encoding="UTF-8" ?>
<container xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://symfony.com/schema/dic/services"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <service id="Setono\SyliusLoyaltyPlugin\Provider\LoyaltyProgramProvider">
            <argument type="service" id="setono_sylius_loyalty.factory.program" />
            <argument type="service" id="setono_sylius_loyalty.repository.program" />
            <argument type="service" id="doctrine" />
        </service>
        <service id="Setono\SyliusLoyaltyPlugin\Provider\LoyaltyProgramProviderInterface"
                 alias="Setono\SyliusLoyaltyPlugin\Provider\LoyaltyProgramProvider" />

        <service id="Setono\SyliusLoyaltyPlugin\Provider\LoyaltyAccountProvider">
            <argument type="service" id="setono_sylius_loyalty.factory.account" />
            <argument type="service" id="setono_sylius_loyalty.repository.account" />
            <argument type="service" id="doctrine" />
        </service>
        <service id="Setono\SyliusLoyaltyPlugin\Provider\LoyaltyAccountProviderInterface"
                 alias="Setono\SyliusLoyaltyPlugin\Provider\LoyaltyAccountProvider" />

        <service id="Setono\SyliusLoyaltyPlugin\Doctrine\ORM\Listener\LoyaltyTransactionDiscriminatorMapListener">
            <argument>%sylius.resources%</argument>
            <tag name="doctrine.event_listener" event="loadClassMetadata" />
        </service>

        <service id="Setono\SyliusLoyaltyPlugin\Ledger\LoyaltyLedger">
            <argument type="service" id="doctrine" />
            <argument type="service" id="event_dispatcher" />
            <call method="setLogger">
                <argument type="service" id="logger" on-invalid="ignore" />
            </call>
        </service>
        <service id="Setono\SyliusLoyaltyPlugin\Ledger\LoyaltyLedgerInterface"
                 alias="Setono\SyliusLoyaltyPlugin\Ledger\LoyaltyLedger" />

        <!-- Earning rule engine: conditions -->
        <service id="Setono\SyliusLoyaltyPlugin\Rule\Condition\OrderTotalAtLeastCondition">
            <tag name="setono_sylius_loyalty.earning_condition" />
        </service>
        <service id="Setono\SyliusLoyaltyPlugin\Rule\Condition\DateWindowCondition">
            <tag name="setono_sylius_loyalty.earning_condition" />
        </service>
        <service id="Setono\SyliusLoyaltyPlugin\Rule\Condition\DayOfWeekCondition">
            <tag name="setono_sylius_loyalty.earning_condition" />
        </service>

        <service id="Setono\SyliusLoyaltyPlugin\Rule\EarningConditionEvaluator">
            <argument type="tagged_locator" tag="setono_sylius_loyalty.earning_condition" default-index-method="getType" />
        </service>
        <service id="Setono\SyliusLoyaltyPlugin\Rule\EarningConditionEvaluatorInterface"
                 alias="Setono\SyliusLoyaltyPlugin\Rule\EarningConditionEvaluator" />

        <!-- Earning rule engine: base amounts -->
        <service id="Setono\SyliusLoyaltyPlugin\Rule\Amount\FixedAmount">
            <tag name="setono_sylius_loyalty.earning_amount" />
        </service>
        <service id="Setono\SyliusLoyaltyPlugin\Rule\Amount\PerAmount">
            <tag name="setono_sylius_loyalty.earning_amount" />
        </service>

        <service id="Setono\SyliusLoyaltyPlugin\Rule\EarningAmountEvaluator">
            <argument type="tagged_locator" tag="setono_sylius_loyalty.earning_amount" default-index-method="getType" />
        </service>
        <service id="Setono\SyliusLoyaltyPlugin\Rule\EarningAmountEvaluatorInterface"
                 alias="Setono\SyliusLoyaltyPlugin\Rule\EarningAmountEvaluator" />

        <!-- Earning rule engine: basis + calculator -->
        <service id="Setono\SyliusLoyaltyPlugin\Rule\Basis\EarningBasisProvider" />
        <service id="Setono\SyliusLoyaltyPlugin\Rule\Basis\EarningBasisProviderInterface"
                 alias="Setono\SyliusLoyaltyPlugin\Rule\Basis\EarningBasisProvider" />

        <service id="Setono\SyliusLoyaltyPlugin\Rule\EarningCalculator">
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Rule\Basis\EarningBasisProviderInterface" />
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Rule\EarningConditionEvaluatorInterface" />
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Rule\EarningAmountEvaluatorInterface" />
        </service>
        <service id="Setono\SyliusLoyaltyPlugin\Rule\EarningCalculatorInterface"
                 alias="Setono\SyliusLoyaltyPlugin\Rule\EarningCalculator" />

        <!-- Order earning pipeline -->
        <service id="Setono\SyliusLoyaltyPlugin\Earning\OrderPointsAwarder">
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Provider\LoyaltyAccountProviderInterface" />
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Provider\LoyaltyProgramProviderInterface" />
            <argument type="service" id="setono_sylius_loyalty.repository.earning_rule" />
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Rule\EarningCalculatorInterface" />
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Rule\Basis\EarningBasisProviderInterface" />
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Ledger\LoyaltyLedgerInterface" />
        </service>
        <service id="Setono\SyliusLoyaltyPlugin\Earning\OrderPointsAwarderInterface"
                 alias="Setono\SyliusLoyaltyPlugin\Earning\OrderPointsAwarder" />

        <service id="Setono\SyliusLoyaltyPlugin\Message\Handler\AwardOrderPointsHandler">
            <argument type="service" id="sylius.repository.order" />
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Earning\OrderPointsAwarderInterface" />
            <tag name="messenger.message_handler" bus="setono_sylius_loyalty.command_bus" />
        </service>

        <!-- Award trigger: hooks both state-machine adapters (workflow tags here; winzou callbacks are
             registered by the extension's prepend). Each only fires under the app's active adapter. -->
        <service id="Setono\SyliusLoyaltyPlugin\Earning\Trigger\AwardOrderPointsTrigger">
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Provider\LoyaltyProgramProviderInterface" />
            <argument type="service" id="setono_sylius_loyalty.command_bus" />
        </service>
        <service id="Setono\SyliusLoyaltyPlugin\Earning\Trigger\AwardOrderPointsTriggerInterface"
                 alias="Setono\SyliusLoyaltyPlugin\Earning\Trigger\AwardOrderPointsTrigger" />

        <service id="Setono\SyliusLoyaltyPlugin\Earning\Trigger\AwardOrderPointsStateMachineListener" public="true">
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Earning\Trigger\AwardOrderPointsTriggerInterface" />
            <tag name="kernel.event_listener" event="workflow.sylius_order_payment.completed.pay" method="onWorkflowPaymentPaid" />
            <tag name="kernel.event_listener" event="workflow.sylius_order.completed.fulfill" method="onWorkflowOrderFulfilled" />
        </service>

        <!-- Clawback trigger: reverses earned points on cancellation / refund. Same both-adapters wiring
             as the award trigger (workflow tags here, winzou callbacks in the extension prepend). -->
        <service id="Setono\SyliusLoyaltyPlugin\Message\Handler\ClawbackOrderPointsHandler">
            <argument type="service" id="sylius.repository.order" />
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Provider\LoyaltyProgramProviderInterface" />
            <argument type="service" id="Setono\SyliusLoyaltyPlugin\Ledger\LoyaltyLedgerInterface" />
            <tag name="messenger.message_handler" bus="setono_sylius_loyalty.command_bus" />
        </service>

        <service id="Setono\SyliusLoyaltyPlugin\Earning\Trigger\ClawbackOrderPointsStateMachineListener" public="true">
            <argument type="service" id="setono_sylius_loyalty.command_bus" />
            <tag name="kernel.event_listener" event="workflow.sylius_order.completed.cancel" method="onWorkflowOrderCancelled" />
            <tag name="kernel.event_listener" event="workflow.sylius_order_payment.completed.refund" method="onWorkflowPaymentRefunded" />
        </service>
    </services>
</container>
