<?xml version="1.0" encoding="UTF-8"?>

<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                                      http://doctrine-project.org/schemas/orm/doctrine-mapping.xsd"
>
    <mapped-superclass name="Setono\SyliusLoyaltyPlugin\Model\EarnOrderLoyaltyTransaction">
        <many-to-one field="order" target-entity="Sylius\Component\Order\Model\OrderInterface">
            <join-column name="order_id" referenced-column-name="id" nullable="true" on-delete="SET NULL" />
        </many-to-one>

        <field name="rulesBreakdown" column="rules_breakdown" type="json" nullable="true" />
        <field name="basisAmount" column="basis_amount" type="integer" nullable="true" />
    </mapped-superclass>
</doctrine-mapping>
