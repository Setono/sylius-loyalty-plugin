<?xml version="1.0" encoding="UTF-8"?>

<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                                      http://doctrine-project.org/schemas/orm/doctrine-mapping.xsd"
>
    <mapped-superclass name="Setono\SyliusLoyaltyPlugin\Model\EarningRule" table="setono_sylius_loyalty__earning_rule">
        <id name="id" column="id" type="integer">
            <generator strategy="AUTO" />
        </id>

        <many-to-one field="channel" target-entity="Sylius\Component\Channel\Model\ChannelInterface">
            <join-column name="channel_id" referenced-column-name="id" nullable="false" on-delete="CASCADE" />
        </many-to-one>

        <field name="name" column="name" type="string" nullable="true" />
        <field name="enabled" column="enabled" type="boolean" />
        <field name="dryRun" column="dry_run" type="boolean" />
        <field name="priority" column="priority" type="integer" />

        <!-- `trigger` is a reserved word in most databases, so the column is named explicitly -->
        <field name="trigger" column="earning_trigger" type="string" nullable="true" />

        <field name="scope" column="scope" type="string" />
        <field name="scopeConfiguration" column="scope_configuration" type="json" />

        <field name="conditionsMatch" column="conditions_match" type="string" />

        <field name="amountType" column="amount_type" type="string" nullable="true" />
        <field name="amountConfiguration" column="amount_configuration" type="json" />

        <field name="startsAt" column="starts_at" type="datetime" nullable="true" />
        <field name="endsAt" column="ends_at" type="datetime" nullable="true" />

        <field name="stackable" column="stackable" type="boolean" />

        <one-to-many field="conditions" target-entity="Setono\SyliusLoyaltyPlugin\Model\EarningRuleConditionInterface" mapped-by="rule">
            <cascade>
                <cascade-persist />
                <cascade-remove />
            </cascade>
            <orphan-removal>true</orphan-removal>
        </one-to-many>
    </mapped-superclass>
</doctrine-mapping>
